function sortByArea(shapes) {
 const areas = shapes.map(shape => {
        if (Array.isArray(shape)) {
            return shape[0] * shape[1]; // Rectangle area
        } else {
            return Math.PI * shape * shape; // Circle area
        }
    });
    return areas.sort((a, b) => a - b);
}
