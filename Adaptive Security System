function breachAttempts(hackers, securityLevel, increase) {
   if (hackers.length === 0) return 0;

    let successfulBreaches = 0;
    let currentSecurityLevel = securityLevel;

    for (let skill of hackers) {
        if (skill > currentSecurityLevel) {
            successfulBreaches++;
        } else {
            currentSecurityLevel += increase;
        }
    }

    return successfulBreaches;
}
