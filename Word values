function wordValue(a) {
  let alphabet = " abcdefghijklmnopqrstuvwxyz";
  let values = [];
  for (let i = 0; i < a.length; i++) {
    values[i] = 0;
    for (let j = 0; j < a[i].length; j++) {
      values[i] += alphabet.indexOf(a[i][j]);
    }
    values[i] *= (i + 1);
  }
  return values;
}
