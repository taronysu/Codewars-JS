Array.prototype.toString = function() {
    const stringify = (arr) => {
        return '[' + arr.map(item => {
            if (Array.isArray(item)) {
                return stringify(item);
            } else if (typeof item === 'string') {
                return `'${item}'`;
            } else {
                return item;
            }
        }).join(',') + ']';
    };
    return stringify(this);
  }
