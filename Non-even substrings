function solve(s){
 const length = s.length;
    let count = 0;
    for (let i = 0; i < length; i++) {
        const temp = s.charCodeAt(i) - '0'.charCodeAt(0);
        if (temp % 2 === 1) {
            count += i + 1;
        }
    }
    return count;
}
